{
  "name": "chamaconnect",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev client/dist --d1 DB=chamaconnect-db --compatibility-date 2025-04-01",
    "build": "cd client && npm install && npm run build",
    "db:migrate:local": "wrangler d1 execute chamaconnect-db --local --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute chamaconnect-db --remote --file=migrations/0001_init.sql",
    "deploy": "wrangler pages deploy client/dist --project-name chamaconnect"
  },
  "dependencies": {
    "hono": "^4.7.0"
  }
}
